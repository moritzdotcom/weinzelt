// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  password            String
  sessions            Session[]
  companyReservations CompanyReservation[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Event {
  id         String      @id @default(uuid())
  name       String
  current    Boolean
  eventDates EventDate[]
  createdAt  DateTime    @default(now())
}

model EventDate {
  id            String         @id @default(uuid())
  date          String
  dow           String
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id])
  seatings      Seating[]
  specialEvents SpecialEvent[]
}

model Seating {
  id                   String                @id @default(uuid())
  eventDate            EventDate             @relation(fields: [eventDateId], references: [id])
  eventDateId          String
  timeslot             String
  availableVip         Int                   @default(10)
  availableStanding    Int                   @default(10)
  minimumSpendVip      Int                   @default(0)
  minimumSpendStanding Int                   @default(0)
  reservations         Reservation[]
  companyReservations  CompanyReservation[]
  externalTicketConfig ExternalTicketConfig?
}

model ExternalTicketConfig {
  id        String  @id @default(uuid())
  seatingId String  @unique
  seating   Seating @relation(fields: [seatingId], references: [id])

  name        String
  ticketPrice Int // in Cent
  required    Boolean @default(true)

  // optional, aber praktisch:
  ticketPerPerson Boolean  @default(true) // wenn z.B. 1 Ticket pro Gast
  createdAt       DateTime @default(now())
}

model Reservation {
  id                  String                   @id @default(uuid())
  type                ReservationType          @default(VIP)
  name                String
  email               String
  people              Int
  seatingId           String
  seating             Seating                  @relation(fields: [seatingId], references: [id])
  paymentStatus       ReservationPaymentStatus @default(DRAFT)
  tableCount          Int                      @default(1)
  minimumSpend        Int                      @default(0)
  externalTicketPrice Int                      @default(0)
  tableNumber         String?
  internalNotes       String?
  notified            DateTime?
  pageVisitId         String?
  pageVisit           PageVisit?               @relation(fields: [pageVisitId], references: [id])
  referralCodeId      String?
  referralCode        ReferralCode?            @relation(fields: [referralCodeId], references: [id])
  createdAt           DateTime                 @default(now())

  billingAddress        Json?
  shippingAddress       Json?
  shippingSameAsBilling Boolean @default(true)

  stripeCheckoutSessionId String?   @unique
  stripePaymentIntentId   String?   @unique
  paidAt                  DateTime?
  manualPaymentTrackedBy  String?

  stripeRefundId String?             @unique
  refundedAmount Int?
  refundReason   String?
  canceledAt     DateTime?
  invoice        ReservationInvoice?
}

model CompanyReservation {
  id          String  @id @default(uuid())
  seatingId   String
  seating     Seating @relation(fields: [seatingId], references: [id])
  name        String
  companyName String?
  email       String
  people      Int
  budget      Int
  text        String?

  billingAddress        Json?
  shippingAddress       Json?
  shippingSameAsBilling Boolean @default(true)

  createdAt   DateTime @default(now())
  userId      String?
  responsible User?    @relation(fields: [userId], references: [id])
}

model ReservationInvoice {
  id            String      @id @default(uuid())
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  // Rechnungsdaten (Snapshot)
  invoiceNumber String    @unique
  issuedAt      DateTime  @default(now())
  sentAt        DateTime?

  // Summen in CENT (sauber, kein Float)
  currency      String @default("EUR")
  subtotalCents Int
  vat7Cents     Int    @default(0)
  vat19Cents    Int    @default(0)
  totalCents    Int

  // optionale Detailzeilen (Snapshot)
  lineItems Json // [{name, qty, unitCents, vatRate, totalCents}...]

  // Empfänger (Snapshot)
  customerName   String
  customerEmail  String
  billingAddress Json?

  createdAt DateTime @default(now())
}

model InvoiceSequence {
  year      Int      @id
  seq       Int
  updatedAt DateTime @updatedAt
}

model PageVisit {
  id           String        @id @default(uuid())
  source       String
  medium       String?
  campaign     String?
  path         String
  ip           String
  country      String?
  region       String?
  city         String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime      @default(now())
  reservations Reservation[]
}

model ReferralCode {
  id           String        @id @default(uuid())
  code         String        @unique()
  description  String
  valid        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  reservations Reservation[]
}

enum SpecialEventCategory {
  WINE_WALK
  WINE_TASTING
  OTHER
}

enum SpecialEventBookingType {
  INTERNAL_REGISTRATION
  EXTERNAL_LINK
  NONE
}

enum EventRegistrationStatus {
  PENDING_PAYMENT
  REGISTERED
  CANCELED
}

model SpecialEvent {
  id          String @id @default(uuid())
  name        String
  description String

  eventDate   EventDate @relation(fields: [eventDateId], references: [id], onDelete: Cascade)
  eventDateId String

  startTime String
  endTime   String

  // Darstellung
  category       SpecialEventCategory @default(OTHER)
  badge          String?
  titleImagePath String?
  priceCents     Int?
  priceLabel     String?
  ctaLabel       String               @default("Jetzt anmelden")
  sortOrder      Int                  @default(0)

  // Anhang
  attachmentPath  String?
  attachmentLabel String?

  // Buchungslogik
  bookingType SpecialEventBookingType @default(INTERNAL_REGISTRATION)
  externalUrl String?

  // Kapazitäten
  capacity                  Int?
  maxPersonsPerRegistration Int  @default(10)

  // Veröffentlichung
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  registrations EventRegistration[]

  @@index([eventDateId, sortOrder])
  @@index([isPublished])
}

model EventRegistration {
  id             String       @id @default(uuid())
  specialEvent   SpecialEvent @relation(fields: [specialEventId], references: [id], onDelete: Cascade)
  specialEventId String

  name        String
  email       String
  phone       String?
  personCount Int

  status     EventRegistrationStatus @default(REGISTERED)
  createdAt  DateTime                @default(now())
  canceledAt DateTime?

  // Payment
  priceCentsTotal         Int?
  stripeCheckoutSessionId String?   @unique
  stripePaymentIntentId   String?
  paidAt                  DateTime?
  paymentExpiresAt        DateTime?

  reminderSent          DateTime?
  reminderLastAttemptAt DateTime?
  reminderAttemptCount  Int       @default(0)
  reminderFailureReason String?

  @@unique([specialEventId, email])
  @@index([specialEventId, status])
  @@index([specialEventId, reminderSent])
  @@index([stripeCheckoutSessionId])
}

model ReservationReminder {
  id           String    @id @default(uuid())
  name         String
  email        String
  createdAt    DateTime  @default(now())
  reminderSent DateTime?
}

enum NewsletterStatus {
  DRAFT
  SENDING
  SENT
}

enum NewsletterRecipientStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model NewsletterSubscription {
  id               String    @id @default(uuid())
  name             String?
  email            String    @unique
  confirmed        Boolean   @default(false)
  confirmedAt      DateTime?
  unsubscribedAt   DateTime?
  unsubscribeToken String?   @unique @default(uuid())
  createdAt        DateTime  @default(now())

  newsletterRecipients NewsletterRecipient[]

  @@index([confirmed, unsubscribedAt])
  @@index([createdAt])
}

model Newsletter {
  id        String           @id @default(uuid())
  subject   String
  headline  String
  body      String
  imageUrl  String?
  imagePath String?
  ctaLabel  String?
  ctaUrl    String?
  status    NewsletterStatus @default(DRAFT)

  createdAt DateTime  @default(now())
  startedAt DateTime?
  sentAt    DateTime?

  recipients NewsletterRecipient[]

  @@index([createdAt])
  @@index([status])
}

model NewsletterRecipient {
  id           String     @id @default(uuid())
  newsletterId String
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  subscriptionId String?
  subscription   NewsletterSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // Snapshot: Diese Daten bleiben bestehen, selbst wenn sich die Subscription ändert.
  email            String
  name             String?
  unsubscribeToken String

  status        NewsletterRecipientStatus @default(PENDING)
  attemptCount  Int                       @default(0)
  lastAttemptAt DateTime?
  sentAt        DateTime?
  failureReason String?

  // Verhindert Doppelversand durch parallele Requests.
  claimToken String?
  sendingAt  DateTime?

  // Tracking pro Empfänger und Newsletter.
  trackingToken String    @unique @default(uuid())
  ctaClickedAt  DateTime?
  ctaClickCount Int       @default(0)

  ctaClicks NewsletterClick[]

  createdAt DateTime @default(now())

  @@unique([newsletterId, email])
  @@index([newsletterId, status, attemptCount])
  @@index([newsletterId, createdAt])
}

model NewsletterClick {
  id                    String              @id @default(uuid())
  newsletterRecipientId String
  newsletterRecipient   NewsletterRecipient @relation(fields: [newsletterRecipientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([newsletterRecipientId, createdAt])
}

model Album {
  id           String            @id @default(uuid())
  year         Int
  day          String // z.B. "opening", "day1", "vip-night"
  photos       ImpressionPhoto[] @relation("AlbumPhotos")
  coverPhotoId String?
  coverPhoto   ImpressionPhoto?  @relation("AlbumCoverPhoto", fields: [coverPhotoId], references: [id])
  createdAt    DateTime          @default(now())

  @@unique([year, day])
}

model ImpressionPhoto {
  id        String   @id @default(uuid())
  path      String // z.B. "2025/opening/uuid.jpg" im Supabase-Bucket
  title     String? // optional
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  width     Int?
  height    Int?
  albumId   String
  album     Album    @relation("AlbumPhotos", fields: [albumId], references: [id])
  coverFor  Album[]  @relation("AlbumCoverPhoto")
}

enum ConfirmationState {
  REQUESTED
  ACCEPTED
  DECLINED
}

enum ReservationPaymentStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELED
}

enum ReservationType {
  VIP
  STANDING
}
